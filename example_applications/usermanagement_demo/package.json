{
	"name": "pict-section-usermanagement-example-demo",
	"version": "0.0.1",
	"description": "Pict Section UserManagement — interactive demo with an in-browser mock auth backend.",
	"main": "source/Pict-Application-UserMgmtDemo.js",
	"scripts": {
		"start": "node source/Pict-Application-UserMgmtDemo.js",
		"build": "npx quack build && npx quack copy",
		"test": "echo \"No tests in the demo.\" && exit 0"
	},
	"author": "Steven Velozo <steven@velozo.com>",
	"license": "MIT",
	"dependencies": {
		"pict": "^1.0.343",
		"pict-application": "^1.0.28",
		"pict-router": "^1.0.4",
		"pict-view": "^1.0.64",
		"pict-provider": "^1.0.3",
		"pict-section-modal": "^1.0.0",
		"pict-section-usermanagement": "^1.0.1"
	},
	"devDependencies": {
		"quackage": "^1.0.58"
	},
	"copyFilesSettings": {
		"whenFileExists": "overwrite"
	},
	"copyFiles": [
		{
			"from": "./html/*",
			"to": "./dist/"
		},
		{
			"from": "./css/**",
			"to": "./dist/css/"
		},
		{
			"from": "./node_modules/pict/dist/*",
			"to": "./dist/js/"
		}
	]
}
